---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import NosotrosSection from '../components/NosotrosSection.astro';
import GaleriaSection from '../components/GaleriaSection.astro';
import ContactoSection from '../components/ContactoSection.astro';
import Footer from '../components/Footer.astro';
import GaleriaModal from '../components/GaleriaModal.astro';
---

<Layout title="Youlex Barbería" description="Tradición y precisión en cada trazo.">
  <div class="flex flex-col min-h-screen md:h-screen">
    <Header />
    <main class="flex-1 min-h-0 flex flex-col md:flex-row">
      <NosotrosSection />
      <GaleriaSection />
      <ContactoSection />
    </main>
    <Footer />
  </div>
  <GaleriaModal />
</Layout>
