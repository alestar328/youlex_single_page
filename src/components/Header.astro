---
import { BUSINESS } from '../data/business';
---

<header class="sticky top-0 w-full z-50 border-b border-[#EAE5D9]/20 bg-[#121212]/90 backdrop-blur-md flex justify-between items-center px-8 h-20 flex-shrink-0">
  <h1 class="text-xl md:text-2xl font-bold tracking-[0.2em] text-[#EAE5D9] font-serif uppercase">
    Youlex Barbería
    <span class="sr-only">— Barbería en Terrassa: cortes de pelo y arreglo de barba</span>
  </h1>

  <nav class="hidden md:flex gap-12">
    <a
      href="#nosotros"
      class="text-[#EAE5D9] font-bold border-b-2 border-[#EAE5D9] pb-1 font-serif uppercase tracking-tighter"
    >
      Nosotros
    </a>
    <button
      id="nav-galeria"
      class="text-stone-400 hover:text-[#EAE5D9] transition-colors font-serif uppercase tracking-tighter cursor-pointer bg-transparent border-none p-0"
    >
      Galería
    </button>
    <a
      href="#contacto"
      class="text-stone-400 hover:text-[#EAE5D9] transition-colors font-serif uppercase tracking-tighter"
    >
      Redes
    </a>
  </nav>

  <a
    href={BUSINESS.booksyUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="bg-[#EAE5D9] text-[#121212] px-4 md:px-6 py-2 uppercase text-xs font-bold tracking-widest hover:opacity-90 transition-all duration-300"
  >
    Reservar
  </a>
</header>

<script>
  document.getElementById('nav-galeria')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-gallery'));
  });
</script>
