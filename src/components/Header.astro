---
import { BUSINESS } from '../data/business';
---

<header class="sticky top-0 w-full z-50 border-b border-[#EAE5D9]/20 bg-[#121212]/90 backdrop-blur-md grid grid-cols-3 items-center px-8 h-28 flex-shrink-0">
  <div></div>

  <h1 class="justify-self-center">
    <img
      src="/logo_white.png"
      alt="Youlex Salón — Barbería en Terrassa: cortes de pelo y arreglo de barba"
      class="h-24 w-auto"
    />
  </h1>

  <a
    href={BUSINESS.booksyUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="justify-self-end bg-[#EAE5D9] text-[#121212] px-4 md:px-6 py-2 uppercase text-xs font-bold tracking-widest hover:opacity-90 transition-all duration-300"
  >
    Reservar
  </a>
</header>
