---
import { BUSINESS } from '../data/business';

// Perfil de Instagram
const instagramUrl = BUSINESS.instagramUrl;

// Publicaciones a incrustar (fotos y videos/reels).
// Pega aquí el enlace de cada post: abre la publicación en Instagram,
// pulsa "..." → "Insertar" o copia la URL del post/reel.
// Formatos válidos:
//   https://www.instagram.com/p/XXXXXXXXXXX/
//   https://www.instagram.com/reel/XXXXXXXXXXX/
const posts: string[] = [
  'https://www.instagram.com/p/DVb1AbEDNT9/',
  'https://www.instagram.com/p/DZLH-maBb1D/',
  'https://www.instagram.com/p/DY5IbbatA8T/',
];
---

<section
  id="contacto"
  class="w-full md:w-1/3 min-h-[600px] md:min-h-0 md:h-full bg-[#131313] flex flex-col overflow-hidden"
>
  <!-- Cabecera -->
  <div class="p-5 pb-3 flex-shrink-0">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-center text-[#EAE5D9] uppercase tracking-tight">
      Redes
    </h2>
    <a
      href={instagramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 flex items-center justify-center gap-2 text-[#d1c5b4] hover:text-[#EAE5D9] transition-colors"
    >
      <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.6"/>
        <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.6"/>
        <circle cx="17.4" cy="6.6" r="1.1" fill="currentColor"/>
      </svg>
      <span class="uppercase text-xs font-bold tracking-widest">@youlex_salon</span>
    </a>
  </div>

  <!-- Galería de publicaciones -->
  <div class="flex-1 min-h-0 overflow-y-auto px-3 pb-3 hide-scrollbar">
    {posts.length > 0 ? (
      <div class="flex flex-col gap-3 items-center w-full max-w-[20rem] md:max-w-[18rem] mx-auto">
        {posts.map((url) => (
          <blockquote
            class="instagram-media !min-w-0 !w-full !max-w-full !m-0 !border-0 !rounded-none"
            data-instgrm-permalink={url}
            data-instgrm-version="14"
          ></blockquote>
        ))}
      </div>
    ) : (
      <a
        href={instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block border border-[#EAE5D9]/20 p-6 text-center hover:border-[#EAE5D9]/50 transition-colors"
      >
        <span class="material-symbols-outlined text-[#EAE5D9] text-4xl">photo_camera</span>
        <p class="mt-2 text-sm text-[#d1c5b4]">
          Síguenos en Instagram para ver nuestros últimos trabajos.
        </p>
        <p class="mt-3 uppercase text-xs font-bold tracking-widest text-[#EAE5D9]">
          Ir al perfil
        </p>
      </a>
    )}
  </div>

  <!-- Ubicación, teléfono y horario -->
  <address class="p-5 pt-3 space-y-3 flex-shrink-0 border-t border-[#EAE5D9]/10 not-italic">
    <a href={BUSINESS.mapsUrl} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 group">
      <span class="material-symbols-outlined text-[#EAE5D9] text-xl">location_on</span>
      <div>
        <p class="uppercase text-xs font-bold tracking-widest text-[#EAE5D9] mb-0.5">Ubicación</p>
        <p class="text-sm text-[#d1c5b4] group-hover:text-[#EAE5D9] transition-colors">
          {BUSINESS.address.street} · {BUSINESS.address.postalCode} {BUSINESS.address.city}
        </p>
      </div>
    </a>

    <a href={`tel:${BUSINESS.phone}`} class="flex items-start gap-3 group">
      <span class="material-symbols-outlined text-[#EAE5D9] text-xl">call</span>
      <div>
        <p class="uppercase text-xs font-bold tracking-widest text-[#EAE5D9] mb-0.5">Teléfono</p>
        <p class="text-sm text-[#d1c5b4] group-hover:text-[#EAE5D9] transition-colors">{BUSINESS.phoneDisplay}</p>
      </div>
    </a>

    <div class="flex items-start gap-3">
      <span class="material-symbols-outlined text-[#EAE5D9] text-xl">schedule</span>
      <div>
        <p class="uppercase text-xs font-bold tracking-widest text-[#EAE5D9] mb-0.5">Horario</p>
        <p class="text-sm text-[#d1c5b4]">{BUSINESS.openingHours.display}</p>
      </div>
    </div>
  </address>
</section>

<script>
  // Carga el script oficial de Instagram y procesa los embeds.
  function processEmbeds() {
    if ((window as any).instgrm) {
      (window as any).instgrm.Embeds.process();
      return;
    }
    if (!document.getElementById('instagram-embed-script')) {
      const s = document.createElement('script');
      s.id = 'instagram-embed-script';
      s.async = true;
      s.src = 'https://www.instagram.com/embed.js';
      document.body.appendChild(s);
    }
  }

  document.addEventListener('DOMContentLoaded', processEmbeds);
  processEmbeds();
</script>
