---
---

<section
  id="contacto"
  class="w-full md:w-1/3 min-h-[600px] md:min-h-0 md:h-full bg-[#131313] flex flex-col p-7 overflow-y-auto hide-scrollbar"
>
  <!-- Formulario -->
  <div class="flex-shrink-0">
    <h2 class="font-serif text-3xl md:text-4xl font-bold text-[#EAE5D9] uppercase tracking-tight mb-4">Contacto</h2>
    <form class="space-y-4">
      <div>
        <input
          type="text"
          placeholder="NOMBRE"
          class="w-full bg-transparent border-b border-[#EAE5D9]/30 focus:border-[#EAE5D9] focus:outline-none text-[#e5e2e1] py-2.5 transition-colors placeholder:text-stone-600 uppercase text-xs tracking-widest font-bold"
        />
      </div>
      <div>
        <input
          type="email"
          placeholder="EMAIL"
          class="w-full bg-transparent border-b border-[#EAE5D9]/30 focus:border-[#EAE5D9] focus:outline-none text-[#e5e2e1] py-2.5 transition-colors placeholder:text-stone-600 uppercase text-xs tracking-widest font-bold"
        />
      </div>
      <div>
        <textarea
          placeholder="MENSAJE"
          rows="2"
          class="w-full bg-transparent border-b border-[#EAE5D9]/30 focus:border-[#EAE5D9] focus:outline-none text-[#e5e2e1] py-2.5 transition-colors placeholder:text-stone-600 uppercase text-xs tracking-widest font-bold resize-none"
        ></textarea>
      </div>
      <button
        type="button"
        class="w-full border border-[#EAE5D9] text-[#EAE5D9] py-2.5 uppercase text-xs font-bold tracking-widest hover:bg-[#EAE5D9] hover:text-[#121212] transition-all duration-500"
      >
        Enviar Mensaje
      </button>
    </form>
  </div>

  <!-- Ubicación -->
  <div class="mt-5 space-y-3 flex-shrink-0">
    <div class="flex items-start gap-3">
      <span class="material-symbols-outlined text-[#EAE5D9] text-xl">location_on</span>
      <div>
        <p class="uppercase text-xs font-bold tracking-widest text-[#EAE5D9] mb-0.5">Ubicación</p>
        <p class="text-sm text-[#d1c5b4]">Calle de la Tradición 42, Barrio Histórico</p>
      </div>
    </div>

    <div class="w-full h-24 bg-[#2a2a2a] border border-[#EAE5D9]/10 relative overflow-hidden">
      <img
        src="/contact_background.JPG"
        alt="Mapa del área"
        class="w-full h-full object-cover grayscale opacity-40"
      />
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="bg-[#EAE5D9] w-3 h-3 rounded-full animate-pulse"></div>
      </div>
    </div>

    <div class="flex items-start gap-3">
      <span class="material-symbols-outlined text-[#EAE5D9] text-xl">schedule</span>
      <div>
        <p class="uppercase text-xs font-bold tracking-widest text-[#EAE5D9] mb-0.5">Horario</p>
        <p class="text-sm text-[#d1c5b4]">Lun – Sáb: 10:00 – 20:00</p>
      </div>
    </div>
  </div>
</section>
